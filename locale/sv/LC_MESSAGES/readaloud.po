#: readaloud/app.py
msgid "Scan printed text and have it read aloud"
msgstr "Skanna tryckt text och få den uppläst"

#: readaloud/window.py
msgid "About"
msgstr "Om"

#: readaloud/window.py
msgid "Quit"
msgstr "Avsluta"

#: readaloud/window.py
msgid "Camera preview will appear here"
msgstr "Kameraförhandsgranskning visas här"

#: readaloud/window.py
msgid "Scan Text"
msgstr "Skanna text"

#: readaloud/window.py
msgid "Take a photo and extract text"
msgstr "Ta ett foto och extrahera text"

#: readaloud/window.py
msgid "Scanned Text"
msgstr "Skannad text"

#: readaloud/window.py
msgid "Language:"
msgstr "Språk:"

#: readaloud/window.py
msgid "Swedish"
msgstr "Svenska"

#: readaloud/window.py
msgid "English"
msgstr "Engelska"

#: readaloud/window.py
msgid "Swedish + English"
msgstr "Svenska + Engelska"

#: readaloud/window.py
msgid "Select OCR and speech language"
msgstr "Välj språk för OCR och tal"

#: readaloud/window.py
msgid "Read Aloud"
msgstr "Läs upp"

#: readaloud/window.py
msgid "Start reading the text aloud"
msgstr "Börja läsa texten högt"

#: readaloud/window.py
msgid "Pause"
msgstr "Pausa"

#: readaloud/window.py
msgid "Pause reading"
msgstr "Pausa uppläsning"

#: readaloud/window.py
msgid "Resume"
msgstr "Fortsätt"

#: readaloud/window.py
msgid "Stop"
msgstr "Stopp"

#: readaloud/window.py
msgid "Stop reading"
msgstr "Stoppa uppläsning"

#: readaloud/window.py
msgid "TTS engine: %s"
msgstr "TTS-motor: %s"

#: readaloud/window.py
msgid "Scanning..."
msgstr "Skannar..."

#: readaloud/window.py
msgid "Could not access camera. Check permissions."
msgstr "Kunde inte komma åt kameran. Kontrollera behörigheter."

#: readaloud/window.py
msgid "No text detected. Try again with better lighting."
msgstr "Ingen text hittades. Försök igen med bättre belysning."

#: readaloud/window.py
msgid "Error"
msgstr "Fel"

#: readaloud/window.py
msgid "OK"
msgstr "OK"
